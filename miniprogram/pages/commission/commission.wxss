.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #CC0000;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
}

.logo-box {
  width: 56rpx;
  height: 56rpx;
  background-color: #fff;
  color: #CC0000;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.header-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.content {
  padding: 30rpx;
}

.card {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.card-img {
  width: 240rpx;
  height: 180rpx;
  border-radius: 8rpx;
  background-color: #eee;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.card-img-red {
  background-color: #CC0000;
}

.card-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #333;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
