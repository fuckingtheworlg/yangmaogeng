.page {
  background: var(--color-bg);
  min-height: 100vh;
}

/* Header */
.header {
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary-dark) 100%);
  padding: 24rpx 30rpx 40rpx;
}
.header-brand {
  display: flex;
  align-items: center;
}
.logo-box {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.95);
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}
.header-text {
  display: flex;
  flex-direction: column;
}
.header-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}
.header-sub {
  color: rgba(255,255,255,0.75);
  font-size: 22rpx;
  margin-top: 4rpx;
}

.content {
  padding: 0 24rpx;
  margin-top: -16rpx;
}

/* Intro */
.intro-text {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* Service Card */
.service-card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 36rpx 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease;
  border-left: 6rpx solid transparent;
}
.service-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-float);
}
.sell-card {
  border-left-color: var(--color-primary);
}
.buy-card {
  border-left-color: var(--color-info);
}

.service-card-left {
  margin-right: 28rpx;
  flex-shrink: 0;
}
.service-icon {
  width: 100rpx;
  height: 100rpx;
}

.service-card-right {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.service-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}
.service-desc {
  font-size: 24rpx;
  color: var(--color-text-hint);
  margin-bottom: 16rpx;
  line-height: 1.5;
}
.service-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.service-action-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
}
.sell-card .icon-right {
  border-color: var(--color-primary);
}
.buy-action .service-action-text {
  color: var(--color-info);
}
.buy-card .icon-right {
  border-color: var(--color-info);
}

/* Guarantee */
.guarantee-section {
  display: flex;
  justify-content: space-between;
  padding: 36rpx 20rpx;
}
.guarantee-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
.guarantee-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-success);
  margin-right: 8rpx;
  flex-shrink: 0;
}
