.page {
  background: var(--color-bg);
  min-height: 100vh;
}

/* Header */
.header {
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary-dark) 100%);
  padding: 24rpx 30rpx 20rpx;
}
.header-brand {
  display: flex;
  align-items: center;
}
.logo-box {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.95);
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
  letter-spacing: -1rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}
.header-text {
  display: flex;
  flex-direction: column;
}
.header-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}
.header-sub {
  color: rgba(255,255,255,0.8);
  font-size: 22rpx;
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}

/* Search */
.search-section {
  background: linear-gradient(180deg, var(--color-primary-dark) 0%, var(--color-bg) 100%);
  padding: 0 24rpx 24rpx;
}
.search-bar {
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-full);
  padding: 8rpx 8rpx 8rpx 24rpx;
  box-shadow: var(--shadow-card);
}
.search-icon {
  color: var(--color-text-hint);
  margin-right: 16rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  height: 60rpx;
  font-size: 26rpx;
  color: var(--color-text);
}
.search-btn {
  padding: 14rpx 32rpx;
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  color: #fff;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(204,0,0,0.25);
}
.search-btn:active {
  opacity: 0.85;
}

/* Banner */
.banner-swiper {
  width: calc(100% - 48rpx);
  height: 320rpx;
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.banner-item {
  width: 100%;
  height: 100%;
  position: relative;
}
.banner-img {
  width: 100%;
  height: 100%;
}
.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 24rpx 20rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.45));
}
.banner-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

/* Filter */
.filter-section {
  padding: 0 0 12rpx;
}
.filter-scroll {
  white-space: nowrap;
}
.filter-bar {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}
.filter-tag {
  display: inline-block;
  padding: 14rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-card);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.25s ease;
  white-space: nowrap;
}
.filter-tag.active {
  color: #fff;
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  box-shadow: 0 4rpx 16rpx rgba(204,0,0,0.25);
}

/* Ship Grid */
.ship-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 16rpx;
  justify-content: space-between;
}
.ship-card {
  width: calc(50% - 12rpx);
  background: var(--color-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  animation: fadeInUp 0.4s ease both;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.ship-card:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-float);
}

.ship-img-wrap {
  position: relative;
  width: 100%;
  height: 240rpx;
  overflow: hidden;
}
.ship-img {
  width: 100%;
  height: 100%;
  background: var(--color-border);
}
.ship-type-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
  backdrop-filter: blur(4px);
}

.ship-info {
  padding: 16rpx 18rpx 20rpx;
}
.ship-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.ship-tonnage {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}
.tonnage-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--color-text-secondary);
  margin-left: 2rpx;
}
.ship-condition {
  flex-shrink: 0;
}
.ship-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.ship-spec {
  font-size: 22rpx;
  color: var(--color-text-hint);
}
.ship-province {
  font-size: 22rpx;
  color: var(--color-text-hint);
}
.ship-bottom {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.ship-price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.ship-no {
  font-size: 20rpx;
  color: var(--color-text-hint);
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ship-name {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-left: 12rpx;
  font-weight: 500;
}
