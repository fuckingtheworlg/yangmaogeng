.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #CC0000;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
}

.logo-box {
  width: 56rpx;
  height: 56rpx;
  background-color: #fff;
  color: #CC0000;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.header-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.banner-swiper {
  width: 100%;
  height: 360rpx;
  background-color: #eee;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.filter-bar {
  display: flex;
  padding: 20rpx 20rpx 10rpx;
  background-color: #fff;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 12rpx 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #fff;
}

.filter-tag.active {
  border-color: #CC0000;
  color: #CC0000;
  background-color: #fff5f5;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: #fff;
  margin-bottom: 10rpx;
}

.search-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.search-btn {
  margin-left: 16rpx;
  padding: 12rpx 28rpx;
  background-color: #CC0000;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.ship-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 10rpx;
  justify-content: space-between;
}

.ship-card {
  width: 48%;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.ship-img {
  width: 100%;
  height: 280rpx;
  background-color: #eee;
}

.ship-info {
  padding: 16rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ship-tonnage {
  font-size: 26rpx;
  color: #333;
}

.ship-price {
  font-size: 26rpx;
  color: #CC0000;
  font-weight: bold;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}
