.page {
  background: var(--color-bg);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.form-scroll {
  flex: 1;
}

/* Form Header */
.form-header {
  padding: 30rpx 30rpx 16rpx;
}
.form-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}
.form-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-hint);
}

/* Form Card */
.form-card {
  background: var(--color-card);
  margin: 16rpx 24rpx;
  padding: 28rpx 28rpx 12rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}
.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 5rpx solid var(--color-info);
}

/* Form Row */
.form-row {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.form-row.no-border {
  border-bottom: none;
}
.form-right {
  flex: 1;
  display: flex;
  align-items: center;
}
.form-label {
  font-size: 26rpx;
  color: var(--color-text);
  width: 130rpx;
  flex-shrink: 0;
  font-weight: 500;
}
.form-input {
  flex: 1;
  height: 68rpx;
  padding: 0 20rpx;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: var(--color-text);
}

/* Grid Input */
.form-row-grid {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.form-row-grid.two-col .grid-item {
  width: calc(50% - 8rpx);
}
.grid-item {
  flex: 1;
}
.grid-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-bottom: 8rpx;
}
.grid-input {
  width: 100%;
  height: 68rpx;
  padding: 0 20rpx;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  text-align: center;
  box-sizing: border-box;
}

/* Textarea */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.7;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

/* Gender */
.gender-group {
  display: flex;
  gap: 12rpx;
}
.gender-item {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  transition: all 0.2s ease;
  font-weight: 500;
}
.gender-item.active {
  color: var(--color-info);
  background: #EBF5FF;
  font-weight: 600;
}

/* Picker */
.form-picker {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 20rpx;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: var(--color-text-hint);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.form-picker.has-value {
  color: var(--color-text);
}

/* Bottom */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-card);
  padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.submit-btn {
  background: linear-gradient(135deg, #3399FF, var(--color-info));
  color: #fff;
  border-radius: var(--radius-full);
  padding: 26rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(22,119,255,0.3);
  transition: all 0.2s;
}
.submit-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
