.page {
  background-color: #fff;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  background-color: #CC0000;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.nav-back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
}

.arrow {
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
}

.logo-box {
  width: 50rpx;
  height: 50rpx;
  background-color: #fff;
  color: #CC0000;
  font-size: 20rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.nav-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.content {
  flex: 1;
  padding-bottom: 120rpx;
}

.section {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  align-items: center;
}

.label {
  color: #666;
  font-size: 26rpx;
}

.value {
  color: #333;
  font-size: 26rpx;
}

.text-bold {
  font-weight: bold;
  text-decoration: underline;
}

.params-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.param-item {
  margin-right: 40rpx;
  margin-bottom: 8rpx;
}

.price-section {
  display: flex;
  align-items: center;
}

.price-value {
  color: #CC0000;
  font-size: 36rpx;
  font-weight: bold;
}

.ship-images {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ship-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #eee;
  padding: 0 30rpx;
  z-index: 100;
}

.fav-btn {
  padding: 16rpx 40rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
  margin-right: 30rpx;
}

.fav-btn.active {
  border-color: #CC0000;
  color: #CC0000;
  background-color: #fff5f5;
}

.contact-info {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
