.page {
  background: var(--color-bg);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Nav Bar */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 99;
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary-dark) 100%);
}
.nav-inner {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
}

.content {
  flex: 1;
}

/* Image Swiper */
.detail-swiper {
  width: 100%;
  height: 420rpx;
}
.detail-img {
  width: 100%;
  height: 100%;
  background: var(--color-border);
}
.detail-img-placeholder {
  width: 100%;
  height: 420rpx;
  background: var(--color-border);
}

/* Price Card */
.price-card {
  background: var(--color-card);
  margin: -20rpx 24rpx 0;
  padding: 28rpx 30rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-float);
  position: relative;
  z-index: 2;
}
.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.detail-price {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--color-primary);
  letter-spacing: -2rpx;
}
.detail-price-unit {
  font-size: 26rpx;
  color: var(--color-primary);
  margin-left: 6rpx;
  font-weight: 500;
}
.ship-condition-badge {
  margin-left: auto;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
}
.tag-good { background: #EBF5FF; color: var(--color-info); }
.tag-excellent { background: #E8F9F0; color: var(--color-success); }
.tag-normal { background: #FFF5E8; color: var(--color-warning); }

.unit-price-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 10rpx 16rpx;
  background: linear-gradient(90deg, #FFF0F0, #FFF8F5);
  border-radius: var(--radius-sm);
}
.unit-price-label {
  font-size: 24rpx;
  color: var(--color-text-hint);
  margin-right: 12rpx;
}
.unit-price-value {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 700;
}

.description-box {
  padding: 8rpx 4rpx;
}
.description-text {
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.7;
  white-space: pre-wrap;
}

.no-row {
  display: flex;
  align-items: center;
}
.ship-no-label {
  font-size: 24rpx;
  color: var(--color-text-hint);
  margin-right: 12rpx;
}
.ship-no-value {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* Section Card */
.section-card {
  background: var(--color-card);
  margin: 20rpx 24rpx 0;
  padding: 28rpx 30rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}
.section-title-bar {
  width: 6rpx;
  height: 30rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
  margin-right: 14rpx;
}

/* Param Grid */
.param-grid {
  display: flex;
  flex-wrap: wrap;
}
.param-cell {
  width: 33.33%;
  padding: 16rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.param-label {
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-bottom: 8rpx;
}
.param-value {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}
.param-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--color-text-secondary);
  margin-left: 2rpx;
}

/* Info List */
.info-list {
  border-top: 1rpx solid var(--color-border);
}
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.info-item.no-border {
  border-bottom: none;
}
.info-label {
  font-size: 26rpx;
  color: var(--color-text-hint);
}
.info-value {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 500;
}
.info-value.highlight {
  color: var(--color-primary);
  font-weight: 700;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-card);
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.action-left {
  margin-right: 24rpx;
}
.fav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}
.fav-btn:active {
  background: var(--color-bg);
}
.fav-label {
  font-size: 20rpx;
  color: var(--color-text-hint);
  margin-top: 4rpx;
}
.fav-btn.active .fav-label {
  color: var(--color-primary);
}

.contact-btn {
  flex: 1;
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  border-radius: var(--radius-full);
  padding: 24rpx 0;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(204,0,0,0.3);
  transition: all 0.2s;
}
.contact-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
.contact-btn-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}
