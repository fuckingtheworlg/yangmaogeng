<view class="page">
  <!-- 顶部导航 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack">
        <view class="icon icon-back"></view>
      </view>
      <view class="logo-box">YMG</view>
      <text class="nav-title">船舶详情</text>
    </view>
  </view>

  <scroll-view scroll-y class="content" enhanced show-scrollbar="{{false}}" style="padding-top: {{navTop}}px;">
    <!-- 船舶图片轮播 -->
    <swiper class="detail-swiper" indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#fff" circular wx:if="{{ship.images.length > 0}}">
      <swiper-item wx:for="{{ship.images}}" wx:key="index">
        <image class="detail-img" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
      </swiper-item>
    </swiper>
    <view class="detail-img-placeholder" wx:else>
      <image src="/images/ship-placeholder.jpg" mode="aspectFill" style="width:100%;height:100%;" />
    </view>

    <!-- 价格与编号 -->
    <view class="price-card">
      <view class="price-row">
        <text class="detail-price">¥{{ship.price}}</text>
        <text class="detail-price-unit">万元</text>
        <view class="ship-condition-badge tag-{{conditionClass}}">{{ship.ship_condition}}</view>
      </view>
      <view class="no-row">
        <text class="ship-no-label">船舶编号</text>
        <text class="ship-no-value">{{ship.ship_no}}</text>
      </view>
    </view>

    <!-- 基本参数 -->
    <view class="section-card">
      <view class="section-title">
        <view class="section-title-bar"></view>
        <text>基本参数</text>
      </view>
      <view class="param-grid">
        <view class="param-cell">
          <text class="param-label">总长</text>
          <text class="param-value">{{ship.total_length}}<text class="param-unit">米</text></text>
        </view>
        <view class="param-cell">
          <text class="param-label">型宽</text>
          <text class="param-value">{{ship.width}}<text class="param-unit">米</text></text>
        </view>
        <view class="param-cell">
          <text class="param-label">型深</text>
          <text class="param-value">{{ship.depth}}<text class="param-unit">米</text></text>
        </view>
        <view class="param-cell">
          <text class="param-label">载重吨</text>
          <text class="param-value">{{ship.deadweight}}<text class="param-unit">吨</text></text>
        </view>
        <view class="param-cell">
          <text class="param-label">总吨</text>
          <text class="param-value">{{ship.gross_tonnage}}<text class="param-unit">吨</text></text>
        </view>
        <view class="param-cell">
          <text class="param-label">船型</text>
          <text class="param-value">{{ship.ship_type}}</text>
        </view>
      </view>
    </view>

    <!-- 建造信息 -->
    <view class="section-card">
      <view class="section-title">
        <view class="section-title-bar"></view>
        <text>建造信息</text>
      </view>
      <view class="info-list">
        <view class="info-item">
          <text class="info-label">建造时间</text>
          <text class="info-value">{{ship.build_date}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">建造省份</text>
          <text class="info-value">{{ship.build_province}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">港籍</text>
          <text class="info-value">{{ship.port_registry}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">水域</text>
          <text class="info-value">{{ship.water_type}}</text>
        </view>
      </view>
    </view>

    <!-- 主机信息 -->
    <view class="section-card">
      <view class="section-title">
        <view class="section-title-bar"></view>
        <text>动力系统</text>
      </view>
      <view class="info-list">
        <view class="info-item">
          <text class="info-label">主机品牌</text>
          <text class="info-value highlight">{{ship.engine_brand}}</text>
        </view>
        <view class="info-item no-border">
          <text class="info-label">主机功率</text>
          <text class="info-value">{{ship.engine_power}} KW</text>
        </view>
      </view>
    </view>

    <view style="height: 160rpx;"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-bottom">
    <view class="action-left">
      <view class="fav-btn {{isFavorited ? 'active' : ''}}" bindtap="toggleFavorite">
        <view class="icon icon-heart {{isFavorited ? 'active' : ''}}"></view>
        <text class="fav-label">{{isFavorited ? '已收藏' : '收藏'}}</text>
      </view>
    </view>
    <view class="contact-btn" bindtap="callPhone">
      <text class="contact-btn-text">立即联系</text>
    </view>
  </view>
</view>
