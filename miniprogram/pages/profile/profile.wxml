<view class="page">
  <!-- 顶部用户区 -->
  <view class="user-header">
    <view class="user-bg"></view>
    <view class="user-card">
      <view class="avatar-wrap">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar-default.png'}}" mode="aspectFill" />
      </view>
      <view class="user-info">
        <text class="username">{{userInfo.nickName || '点击登录'}}</text>
        <text class="user-desc">欢迎使用羊毛梗船舶服务</text>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-section">
    <view class="tab-bar">
      <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
        <text class="tab-count">{{favorites.length}}</text>
        <text class="tab-label">我的收藏</text>
      </view>
      <view class="tab-divider"></view>
      <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
        <text class="tab-count">{{commissions.length}}</text>
        <text class="tab-label">我的委托</text>
      </view>
    </view>
  </view>

  <!-- 收藏列表 -->
  <view class="list-section" wx:if="{{currentTab === 0}}">
    <view class="list-card" wx:for="{{favorites}}" wx:key="id" bindtap="goDetail" data-id="{{item.ship_id}}" style="animation-delay: {{index * 0.06}}s">
      <view class="list-card-left">
        <text class="list-no">{{item.ship_no}}</text>
        <text class="list-tonnage">{{item.deadweight}} 吨</text>
      </view>
      <view class="list-card-right">
        <text class="list-price">¥{{item.price}}<text class="price-unit-sm">万</text></text>
        <view class="icon icon-right"></view>
      </view>
    </view>
    <view class="empty-state" wx:if="{{favorites.length === 0}}">
      <image class="empty-img" src="/images/empty-state.png" mode="aspectFit" />
      <text class="empty-text">暂无收藏船舶</text>
    </view>
  </view>

  <!-- 委托列表 -->
  <view class="list-section" wx:if="{{currentTab === 1}}">
    <view class="list-card" wx:for="{{commissions}}" wx:key="id" style="animation-delay: {{index * 0.06}}s">
      <view class="list-card-left">
        <view class="commission-type-wrap">
          <text class="commission-type {{item.type === 'sell' ? 'type-sell' : 'type-buy'}}">
            {{item.type === 'sell' ? '出售' : '求购'}}
          </text>
        </view>
        <text class="list-no">NO.{{item.id}}</text>
      </view>
      <view class="list-card-right">
        <text class="commission-status {{item.status === 1 ? 'status-done' : 'status-pending'}}">
          {{item.status === 1 ? '已处理' : '待处理'}}
        </text>
      </view>
    </view>
    <view class="empty-state" wx:if="{{commissions.length === 0}}">
      <image class="empty-img" src="/images/empty-state.png" mode="aspectFit" />
      <text class="empty-text">暂无委托记录</text>
    </view>
  </view>
</view>
