<view class="page">
  <!-- 顶部用户区 -->
  <view class="user-header">
    <view class="user-bg"></view>
    <view class="user-card" bindtap="onLogin">
      <view class="avatar-wrap">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar-default.png'}}" mode="aspectFill" />
      </view>
      <view class="user-info">
        <text class="username">{{isLogin ? userInfo.nickName : '点击登录'}}</text>
        <text class="user-desc">{{isLogin ? '欢迎使用羊毛梗船舶服务' : '登录后可使用收藏和委托功能'}}</text>
      </view>
      <!-- 退出按钮 -->
      <view class="logout-btn" wx:if="{{isLogin}}" catchtap="onLogout">
        <text class="logout-text">退出</text>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-section">
    <view class="tab-bar">
      <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
        <text class="tab-count">{{favorites.length}}</text>
        <text class="tab-label">我的收藏</text>
      </view>
      <view class="tab-divider"></view>
      <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
        <text class="tab-count">{{commissions.length}}</text>
        <text class="tab-label">我的委托</text>
      </view>
    </view>
  </view>

  <!-- 收藏列表 -->
  <view class="list-section" wx:if="{{currentTab === 0}}">
    <view class="list-card" wx:for="{{favorites}}" wx:key="id" style="animation-delay: {{index * 0.06}}s">
      <view class="list-card-left" bindtap="goDetail" data-id="{{item.ship_id}}">
        <text class="list-no">{{item.ship_no}}</text>
        <view class="list-meta">
          <text class="list-tonnage">{{item.deadweight}} 吨</text>
          <text class="list-type">{{item.ship_type}}</text>
        </view>
      </view>
      <view class="list-card-right">
        <text class="list-price">¥{{item.price}}<text class="price-unit-sm">万</text></text>
        <view class="unfav-btn" catchtap="removeFavorite" data-id="{{item.ship_id}}">取消</view>
      </view>
    </view>
    <view class="empty-state" wx:if="{{favorites.length === 0}}">
      <image class="empty-img" src="/images/empty-state.png" mode="aspectFit" />
      <text class="empty-text">暂无收藏船舶</text>
      <text class="empty-hint" wx:if="{{!isLogin}}">登录后可在详情页收藏船舶</text>
    </view>
  </view>

  <!-- 委托列表 -->
  <view class="list-section" wx:if="{{currentTab === 1}}">
    <view class="list-card" wx:for="{{commissions}}" wx:key="id" style="animation-delay: {{index * 0.06}}s">
      <view class="list-card-left">
        <view class="commission-type-wrap">
          <text class="commission-type {{item.type === 'sell' ? 'type-sell' : 'type-buy'}}">
            {{item.type === 'sell' ? '出售' : '求购'}}
          </text>
        </view>
        <text class="list-no">{{item.contact_name}} {{item.gender || ''}}</text>
        <text class="list-tonnage" wx:if="{{item.deadweight}}">{{item.deadweight}} 吨</text>
      </view>
      <view class="list-card-right">
        <text class="commission-time">{{item.create_time}}</text>
        <text class="commission-status {{item.status === 1 ? 'status-done' : 'status-pending'}}">
          {{item.status === 1 ? '已处理' : '待处理'}}
        </text>
      </view>
    </view>
    <view class="empty-state" wx:if="{{commissions.length === 0}}">
      <image class="empty-img" src="/images/empty-state.png" mode="aspectFit" />
      <text class="empty-text">暂无委托记录</text>
      <text class="empty-hint">可在委托页面提交出售或求购需求</text>
    </view>
  </view>

  <!-- 登录弹窗 -->
  <view class="login-mask" wx:if="{{showLoginModal}}" bindtap="closeLoginModal">
    <view class="login-modal" catchtap="">
      <view class="login-modal-header">
        <text class="login-modal-title">微信账号登录</text>
        <text class="login-modal-subtitle">请授权获取微信头像和昵称</text>
      </view>

      <view class="login-row">
        <text class="login-row-label">头像</text>
        <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{tempAvatar || '/images/avatar-default.png'}}" mode="aspectFill" />
          <text class="avatar-picker-hint" wx:if="{{!tempAvatar}}">点击选择</text>
        </button>
      </view>

      <view class="login-row">
        <text class="login-row-label">昵称</text>
        <input
          class="nickname-input"
          type="nickname"
          placeholder="请输入昵称"
          value="{{tempNickname}}"
          bindchange="onNicknameInput"
          bindinput="onNicknameInput"
        />
      </view>

      <view class="login-actions">
        <view class="login-btn cancel" bindtap="closeLoginModal">取消</view>
        <view class="login-btn confirm" bindtap="confirmLogin">确认登录</view>
      </view>
    </view>
  </view>
</view>
