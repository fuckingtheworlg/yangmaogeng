.page {
  background: var(--color-bg);
  min-height: 100vh;
}

/* User Header */
.user-header {
  position: relative;
  padding-bottom: 40rpx;
}
.user-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary-dark) 100%);
}
.user-card {
  position: relative;
  display: flex;
  align-items: center;
  padding: 60rpx 36rpx 36rpx;
  z-index: 1;
}
.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
  margin-right: 28rpx;
  flex-shrink: 0;
}
.avatar {
  width: 100%;
  height: 100%;
  background: var(--color-bg);
}
.user-info {
  flex: 1;
  min-width: 0;
}

/* Logout Button */
.logout-btn {
  padding: 10rpx 24rpx;
  border: 2rpx solid rgba(255,255,255,0.6);
  border-radius: var(--radius-full);
  flex-shrink: 0;
}
.logout-btn:active {
  background: rgba(255,255,255,0.15);
}
.logout-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
}
.username {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}
.user-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

/* Tab Section */
.tab-section {
  margin: -16rpx 24rpx 20rpx;
  position: relative;
  z-index: 2;
}
.tab-bar {
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-float);
  padding: 8rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  transition: all 0.25s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.tab-item.active {
  background: var(--color-primary-bg);
}
.tab-divider {
  width: 1rpx;
  background: var(--color-border);
  margin: 16rpx 0;
}
.tab-count {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--color-text);
}
.tab-item.active .tab-count {
  color: var(--color-primary);
}
.tab-label {
  font-size: 22rpx;
  color: var(--color-text-hint);
}
.tab-item.active .tab-label {
  color: var(--color-primary);
  font-weight: 600;
}

/* List */
.list-section {
  padding: 0 24rpx;
}
.list-card {
  background: var(--color-card);
  padding: 28rpx 28rpx;
  margin-bottom: 12rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow-card);
  animation: fadeInUp 0.35s ease both;
  transition: transform 0.2s;
}
.list-card:active {
  transform: scale(0.98);
}
.list-card-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.list-card-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.list-no {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 500;
}
.list-meta {
  display: flex;
  gap: 16rpx;
}
.list-tonnage {
  font-size: 22rpx;
  color: var(--color-text-hint);
}
.list-type {
  font-size: 22rpx;
  color: var(--color-text-hint);
}

/* Unfavorite Button */
.unfav-btn {
  font-size: 22rpx;
  color: var(--color-text-hint);
  padding: 6rpx 16rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-full);
}
.unfav-btn:active {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border-color: var(--color-primary);
}
.list-price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.price-unit-sm {
  font-size: 20rpx;
  font-weight: 400;
}

/* Commission */
.commission-type-wrap {
  margin-bottom: 4rpx;
}
.commission-type {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
}
.type-sell {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}
.type-buy {
  background: #EBF5FF;
  color: var(--color-info);
}

.commission-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}
.status-pending {
  background: #FFF5E8;
  color: var(--color-warning);
}
.status-done {
  background: #E8F9F0;
  color: var(--color-success);
}
.commission-time {
  font-size: 20rpx;
  color: var(--color-text-hint);
}

/* Empty Hint */
.empty-hint {
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-top: 8rpx;
}

.list-card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

/* Login Modal */
.login-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
}
.login-modal {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 40rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2);
}
.login-modal-header {
  text-align: center;
  margin-bottom: 32rpx;
}
.login-modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 10rpx;
}
.login-modal-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-hint);
}
.login-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.login-row-label {
  width: 100rpx;
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}
.avatar-actions {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
}
.avatar-preview {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
}
.avatar-wx-btn {
  margin: 0;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  border-radius: 100rpx;
  line-height: 1.6;
  border: none;
}
.avatar-wx-btn::after {
  border: none;
}
.login-tip {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-top: 14rpx;
  line-height: 1.6;
}
.nickname-input {
  flex: 1;
  height: 68rpx;
  font-size: 28rpx;
  color: var(--color-text);
  text-align: right;
}
.login-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.login-btn {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 100rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s;
}
.login-btn.cancel {
  background: var(--color-bg);
  color: var(--color-text-secondary);
}
.login-btn.cancel:active {
  opacity: 0.7;
}
.login-btn.confirm {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(204,0,0,0.25);
}
.login-btn.confirm:active {
  transform: scale(0.97);
  opacity: 0.9;
}
