.page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #CC0000;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
}

.logo-box {
  width: 56rpx;
  height: 56rpx;
  background-color: #fff;
  color: #CC0000;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.header-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.user-section {
  background-color: #fff;
  padding: 50rpx 30rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.avatar-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2rpx solid #ddd;
  margin-right: 30rpx;
}

.avatar {
  width: 100%;
  height: 100%;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.tab-bar {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #333;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #CC0000;
}

.list {
  padding: 10rpx 20rpx;
}

.list-item {
  background-color: #fff;
  padding: 28rpx 30rpx;
  margin-bottom: 10rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-no {
  font-size: 26rpx;
  color: #333;
}

.item-tonnage {
  font-size: 26rpx;
  color: #666;
}

.item-price {
  font-size: 26rpx;
  color: #CC0000;
  font-weight: bold;
}

.item-type {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-weight: bold;
}

.type-sell {
  color: #CC0000;
  background-color: #fff5f5;
}

.type-buy {
  color: #CC0000;
  background-color: #fff5f5;
}

.empty {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}
