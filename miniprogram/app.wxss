@import './utils/icons.wxss';

page {
  --color-primary: #CC0000;
  --color-primary-light: #FF2222;
  --color-primary-bg: #FFF5F5;
  --color-primary-dark: #A00000;
  --color-text: #1A1A2E;
  --color-text-secondary: #5A5A72;
  --color-text-hint: #9E9EB8;
  --color-bg: #F4F5F9;
  --color-card: #FFFFFF;
  --color-border: #EDEDF0;
  --color-success: #00B578;
  --color-warning: #FF8F1F;
  --color-info: #1677FF;
  --shadow-card: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  --shadow-float: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 999rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

view, text, scroll-view {
  box-sizing: border-box;
}

/* Layout Utilities */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-col { display: flex; flex-direction: column; }

/* Text Utilities */
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-hint { color: var(--color-text-hint); }
.text-bold { font-weight: 600; }
.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* Price */
.price {
  color: var(--color-primary);
  font-weight: 700;
}
.price-unit {
  font-size: 22rpx;
  font-weight: 400;
  margin-left: 4rpx;
}

/* Buttons */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary) 100%);
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(204, 0, 0, 0.3);
  transition: all 0.2s ease;
}
.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.9;
}
.btn-primary::after { border: none; }

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-full);
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
  transition: all 0.2s ease;
}
.btn-outline:active {
  background: var(--color-primary-bg);
}

/* Card */
.card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

/* Divider */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 20rpx 0;
}

/* Page Header (Tab pages) */
.page-header {
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary-dark) 100%);
  color: #fff;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
}
.page-header .logo {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.95);
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  letter-spacing: -1rpx;
}
.page-header .header-title {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* Nav Bar (Sub pages) — padding-top set dynamically via JS statusBarHeight */
.nav-bar {
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary-dark) 100%);
}
.nav-inner {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
}
.nav-back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  transition: background 0.2s;
}
.nav-back:active {
  background: rgba(255,255,255,0.3);
}
.nav-bar .logo-box {
  width: 50rpx;
  height: 50rpx;
  background: rgba(255,255,255,0.95);
  color: var(--color-primary);
  font-size: 20rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.nav-bar .nav-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Tag/Badge */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  font-weight: 500;
}
.tag-red { background: var(--color-primary-bg); color: var(--color-primary); }
.tag-blue { background: #EBF5FF; color: var(--color-info); }
.tag-green { background: #E8F9F0; color: var(--color-success); }
.tag-orange { background: #FFF5E8; color: var(--color-warning); }

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}
.empty-state .empty-img {
  width: 240rpx;
  height: 180rpx;
  margin-bottom: 24rpx;
  opacity: 0.7;
}
.empty-state .empty-text {
  color: var(--color-text-hint);
  font-size: 26rpx;
}

/* Safe area */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* Animations */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.animate-in {
  animation: fadeInUp 0.35s ease forwards;
}
