page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.container {
  padding: 20rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.text-red {
  color: #CC0000;
}

.text-gray {
  color: #999;
}

.text-bold {
  font-weight: bold;
}

.price {
  color: #CC0000;
  font-weight: bold;
}

.btn-primary {
  background-color: #CC0000;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.divider {
  height: 1rpx;
  background-color: #eee;
  margin: 20rpx 0;
}

.page-header {
  background-color: #CC0000;
  color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
}

.page-header .logo {
  width: 50rpx;
  height: 50rpx;
  background-color: #fff;
  color: #CC0000;
  font-size: 20rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  border-radius: 6rpx;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
