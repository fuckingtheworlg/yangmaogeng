/* ========================================
   CSS Icon System — Pure CSS vector icons
   用 CSS 绘制的矢量图标，替代文字符号
   ======================================== */

/* Base icon */
.icon {
  display: inline-block;
  position: relative;
  vertical-align: middle;
}

/* ← Back Arrow */
.icon-back {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(45deg);
}

/* Search magnifier */
.icon-search {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}
.icon-search::after {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 4rpx;
  background: currentColor;
  bottom: -4rpx;
  right: -6rpx;
  transform: rotate(-45deg);
  border-radius: 2rpx;
}

/* Heart / Favorite */
.icon-heart {
  width: 36rpx;
  height: 32rpx;
}
.icon-heart::before,
.icon-heart::after {
  content: '';
  position: absolute;
  top: 0;
  width: 18rpx;
  height: 28rpx;
  border-radius: 18rpx 18rpx 0 0;
  background: #ccc;
}
.icon-heart::before {
  left: 0;
  transform: rotate(-45deg);
  transform-origin: bottom left;
}
.icon-heart::after {
  right: 0;
  transform: rotate(45deg);
  transform-origin: bottom right;
}
.icon-heart.active::before,
.icon-heart.active::after {
  background: #CC0000;
}

/* Phone */
.icon-phone {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}
.icon-phone::before {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 6rpx;
  background: currentColor;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-30deg);
  border-radius: 2rpx;
}

/* Camera / Upload */
.icon-camera {
  width: 40rpx;
  height: 32rpx;
  border: 3rpx solid #bbb;
  border-radius: 6rpx;
  position: relative;
}
.icon-camera::before {
  content: '';
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid #bbb;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.icon-camera::after {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 6rpx;
  background: #bbb;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 3rpx 3rpx 0 0;
}

/* Plus */
.icon-plus {
  width: 40rpx;
  height: 40rpx;
}
.icon-plus::before,
.icon-plus::after {
  content: '';
  position: absolute;
  background: #bbb;
  border-radius: 2rpx;
}
.icon-plus::before {
  width: 4rpx;
  height: 40rpx;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}
.icon-plus::after {
  width: 40rpx;
  height: 4rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
}

/* Right arrow (chevron) */
.icon-right {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #ccc;
  border-bottom: 3rpx solid #ccc;
  transform: rotate(-45deg);
}

/* Star */
.icon-star {
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 10rpx solid #FFB800;
  position: relative;
}
.icon-star::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: -14rpx;
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-top: 10rpx solid #FFB800;
}

/* Location pin */
.icon-location {
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
}
.icon-location::after {
  content: '';
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: currentColor;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
